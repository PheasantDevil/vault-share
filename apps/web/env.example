# このファイルを .env.local にコピーして値を設定してください。
# cp env.example .env.local

# Firebase (Identity Platform) - クライアント用（NEXT_PUBLIC_ はブラウザに露出します）
# API Key は Firebase コンソール > プロジェクトの設定 > 全般 > マイアプリ で取得
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=vault-share-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=vault-share-dev

# 許可するメールアドレス（カンマ区切り）。ログイン・新規登録はこのリストのみ成功。
# パスワードは Identity Platform が管理（ハッシュ保存）。当アプリでは持たない。
ALLOWED_EMAILS=user1@example.com,user2@example.com

# セッション Cookie の JWT 署名用。以下で生成した値を指定（16 文字以上推奨）:
#   openssl rand -base64 32
# 本番と開発では別の値を使用すること。
SESSION_SECRET=

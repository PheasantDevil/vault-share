{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate-docs": "tsx scripts/generate-docs-data.ts",
    "predev": "pnpm run generate-docs",
    "prebuild": "pnpm run generate-docs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:with-emulators": "cd ../.. && env FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 SESSION_SECRET=test-secret-key-for-integration-tests-min-16-chars ITEM_ENCRYPTION_KEY=QkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkJCQkI= pnpm --filter web exec firebase emulators:exec --only firestore,auth --project test-project \"pnpm test:integration\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed:e2e": "tsx scripts/seed-e2e-user.ts",
    "clear:firestore-group-data": "tsx scripts/clear-firestore-group-data.ts"
  },
  "dependencies": {
    "@vault-share/api-client": "workspace:*",
    "@vault-share/crypto": "workspace:*",
    "@vault-share/db": "workspace:*",
    "firebase": "^11.0.0",
    "firebase-admin": "^12.0.0",
    "focus-trap-react": "^12.0.0",
    "fuse.js": "^7.1.0",
    "jose": "^5.9.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "firebase-tools": "^13.0.0",
    "jsdom": "^23.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}

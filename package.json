{
  "name": "vault-share",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm -r run test",
    "connect:up": "docker compose --project-directory infra/1password-connect -f infra/1password-connect/docker-compose.yaml up -d",
    "connect:down": "docker compose --project-directory infra/1password-connect -f infra/1password-connect/docker-compose.yaml down",
    "connect:logs": "docker compose --project-directory infra/1password-connect -f infra/1password-connect/docker-compose.yaml logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
